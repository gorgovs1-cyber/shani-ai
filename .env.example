# ==== Analytics dashboard env ====
# Copy to .env.local for local dev, and add the same keys in Vercel > Project > Settings > Environment Variables.
# Never commit real values. Server-side only, none of these are NEXT_PUBLIC.

# --- Instagram (Instagram API with Instagram Login) ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Must match exactly what is registered in the Meta app.
# Local:      http://localhost:3000/api/auth/instagram/callback
# Production: https://<your-domain>/api/auth/instagram/callback
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback

# --- Supabase (existing project) ---
SUPABASE_URL=
# Service role key, server only. Gives full access, keep it secret.
SUPABASE_SERVICE_ROLE_KEY=

# --- Vercel Web Analytics API ---
# Create at Vercel > Account Settings > Tokens.
VERCEL_TOKEN=
# shani-ai project id, from Project > Settings > General.
VERCEL_PROJECT_ID=
# Leave empty for a personal (Hobby) account. Fill only for a team.
VERCEL_TEAM_ID=

# --- Protects the daily cron route from public calls ---
CRON_SECRET=

# ==== Marketing measurement (client-side tags — safe to expose) ====
# These ARE NEXT_PUBLIC on purpose: they render into GA4 / Meta Pixel client tags.
# Leave empty and the tags simply don't load (site still builds & runs).
# GA4 Measurement ID, from Google Analytics > Admin > Data Streams (format G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=
# Meta Pixel ID, from Meta Events Manager > Data Sources (numeric, e.g. 123456789012345)
NEXT_PUBLIC_META_PIXEL_ID=
